# AI Service API Keys
VITE_OPENAI_API_KEY=your_openai_api_key_here
VITE_STABILITY_API_KEY=your_stability_ai_api_key_here
VITE_REPLICATE_API_KEY=your_replicate_api_key_here
VITE_RUNWAY_API_KEY=your_runway_api_key_here

# Email Service (Resend)
# Get free API key from https://resend.com (3,000 emails/month free)
# Then add to Supabase Edge Function Secrets: RESEND_API_KEY=your_key_here
RESEND_API_KEY=re_your_resend_api_key_here

# Note: In production, these should be handled by a backend service
# for security reasons. Never expose API keys in client-side code.